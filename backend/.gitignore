# ============================================================
# Brandflow AI — .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# Virtual Environments
venv/
.venv/
env/
ENV/

# Environment Variables — NEVER commit secrets
.env
!.env.example

# IDEs & Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Distribution / Build
dist/
build/
*.egg-info/
*.egg

# Test & Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
