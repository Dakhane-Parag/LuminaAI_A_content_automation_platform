# ============================================================
# BrandFlow AI — PRODUCTION Environment Configuration
# ============================================================
# Copy this file to .env on your EC2 server and fill ALL values.
# NEVER commit .env to Git.
#
# How to copy to EC2:
#   scp -i "brandflow-key.pem" .env ubuntu@<EC2-IP>:/home/ubuntu/app/backend/.env
#
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="Brandflow AI"
APP_VERSION="1.0.0"
ENVIRONMENT=production
DEBUG=False

# ── API ──────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1

# ── MongoDB Atlas ─────────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/brandflow_ai
MONGODB_DB_NAME=brandflow_ai

# ── JWT ───────────────────────────────────────────────────────
# Generate secure key on EC2:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_GENERATED_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────
# Add your Vercel frontend URL. Multiple origins = comma separated.
# Example: https://brandflow-ai.vercel.app,http://YOUR_EC2_IP
ALLOWED_ORIGINS=https://YOUR_APP.vercel.app,http://YOUR_EC2_IP

# ── Security ─────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ── Replicate (Image Generation) ─────────────────────────────
REPLICATE_API_TOKEN=YOUR_REPLICATE_API_TOKEN

# ── AWS S3 (Image Storage) ───────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=YOUR_BUCKET_NAME

# ── Redis — Upstash ──────────────────────────────────────────
# Get this from Upstash dashboard → your database → "Connection" tab
# Format: rediss://default:TOKEN@host.upstash.io:PORT
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:PORT

# ── Meta / Instagram ─────────────────────────────────────────
META_APP_ID=YOUR_META_APP_ID
META_APP_SECRET=YOUR_META_APP_SECRET
# This MUST match exactly what's in Meta App Dashboard → Facebook Login → Valid OAuth Redirect URIs
META_REDIRECT_URI=https://YOUR_APP.vercel.app/auth/instagram/callback
